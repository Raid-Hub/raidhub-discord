PORT=8787
# debug | info | warn | error (matches RaidHub-Services / RaidHub-API LOG_LEVEL)
LOG_LEVEL=info

DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_SYNC_DRY_RUN=false
# Must be reachable from this process (cloud Discord ingress cannot use localhost to reach your laptop).
RAIDHUB_API_BASE_URL=http://localhost:8000
# Same string as a "key" entry in RaidHub-API/api-keys.json (required when API runs with PROD=true).
RAIDHUB_API_KEY=
# Same value as RaidHub-API JWT_SECRET if you use signed Discord calls.
RAIDHUB_JWT_SECRET=
